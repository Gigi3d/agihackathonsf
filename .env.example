# ─────────────────────────────────────────────────────────────────────────────
# Runtype secrets — configure these in the Runtype dashboard
#   (Settings → Secrets), NOT in this file. They are referenced in tool/flow
#   configs as {{secret:NAME}}. This file only documents the NAMES.
# ─────────────────────────────────────────────────────────────────────────────

# HMAC secret you also set on the GitHub org webhook (X-Hub-Signature-256).
# Generate: openssl rand -hex 20
GITHUB_WEBHOOK_SECRET=

# GitHub fine-grained PAT for the weekly leaderboard commit search.
# Permissions: Repository → Contents: Read-only, Metadata: Read-only.
GITHUB_API_TOKEN=

# Giphy API key (developers.giphy.com → Create App → API).
GIPHY_API_KEY=

# Telegram bot token from @BotFather (format 1234567890:AA...).
TELEGRAM_BOT_TOKEN=

# Target Telegram chat id (-100...) or @channelusername. Bot must be an admin.
TELEGRAM_CHAT_ID=

# Discord channel Incoming Webhook URL (Server Settings → Integrations → Webhooks).
DISCORD_WEBHOOK_URL=

# Slack Incoming Webhook URL (api.slack.com/apps → Incoming Webhooks).
SLACK_WEBHOOK_URL=

# ─────────────────────────────────────────────────────────────────────────────
# X / Twitter OAuth2 (PUBLIC client, PKCE) — NOT a Runtype secret.
# Stored in a Runtype Record `x_oauth/x_token` with metadata:
#   clientId     = your X app Client ID (public client, no secret)
#   refreshToken = seed refresh token from the one-time PKCE authorization
#   accessToken  = ""   (the flow fills this)
#   expiresAt    = 0    (the flow fills this)
# The x-post-auto flow refreshes the access token and rotates the refresh token
# automatically on every post.
# ─────────────────────────────────────────────────────────────────────────────
